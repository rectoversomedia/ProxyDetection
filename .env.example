# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# PROXY PROVIDERS
# ============================================================================

# DataImpulse - https://dataimpulse.com/
DAT_IMPULSE_API_KEY=

# Decodo - https://decodo.com/
DECODO_API_KEY=

# Custom proxy list file path
PROXY_FILE_PATH=

# ============================================================================
# BROWSER SETTINGS
# ============================================================================

# Browser type: camoufox, playwright, or auto
BROWSER_TYPE=camoufox

# Browser executable paths
CAMOUFOX_PATH=
PLAYWRIGHT_BROWSERS_PATH=

# Headless mode (true/false)
BROWSER_HEADLESS=false

# ============================================================================
# SUBMISSION SETTINGS
# ============================================================================

# Default delay between submissions (seconds)
DEFAULT_DELAY=5

# Maximum parallel submissions
MAX_PARALLEL=3

# Retry count for failed submissions
MAX_RETRIES=3

# ============================================================================
# DATABASE
# ============================================================================

# Database path (relative to project root or absolute)
DATABASE_PATH=data/proxy_detection.db

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# ============================================================================
# SESSION
# ============================================================================

# Session timeout in seconds
SESSION_TIMEOUT=300

# Browser profile directory
PROFILE_DIR=configs/profiles

# ============================================================================
# SCREENSHOT
# ============================================================================

# Save screenshots on errors
SAVE_ERROR_SCREENSHOTS=true

# Screenshot directory
SCREENSHOT_DIR=logs/screenshots
